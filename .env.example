# ============================================================
# ResuMatch AI — Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` file (it is git-ignored).
# ============================================================

# --- Server-side only (NEVER exposed to the browser) ---

# Google Gemini API key. Used exclusively by the Express server
# to make AI calls. The frontend never sees this value.
GEMINI_API_KEY="your_gemini_api_key_here"

# Gemini model id used for all AI calls. Optional — defaults to
# "gemini-2.0-flash" if not set.
GEMINI_MODEL="gemini-2.0-flash"

# Node environment: "development" or "production".
NODE_ENV="development"

# Port the Express server listens on. Optional — defaults to 3000.
PORT="3000"
