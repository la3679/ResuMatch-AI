# ============================================================
# ResuMatch AI — Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` file (it is git-ignored).
# ============================================================

# --- Server-side only (NEVER exposed to the browser) ---
#
# On Vercel, set these in: Project → Settings → Environment Variables.
# They are read only by the server-side API routes (api/**). Never use a
# VITE_ prefix for the Gemini key, or it would be bundled into the client.

# Google Gemini API key. Used by the backend only (Express server in local
# dev, Vercel serverless functions in production). The frontend never sees it.
GEMINI_API_KEY="your_gemini_api_key_here"

# Gemini model id used for all AI calls. Optional — defaults to
# "gemini-2.0-flash" if not set.
GEMINI_MODEL="gemini-2.0-flash"

# Node environment: "development" or "production".
NODE_ENV="development"

# Port the Express server listens on. Optional — defaults to 3000.
PORT="3000"
